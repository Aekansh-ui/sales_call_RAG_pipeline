# =============================================================================
# Sales Call RAG Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is never committed to git. This file (.env.example) is — it documents
# what variables exist without exposing real secrets.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sales_rag

# Full connection URL used by Python (psycopg2 / SQLAlchemy / LangChain)
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Host is "postgres" — the Docker service name, not localhost
DATABASE_URL=postgresql://raguser:changeme@postgres:5432/sales_rag

# --- Ollama ---
# Host is "ollama" — the Docker service name, not localhost
OLLAMA_BASE_URL=http://ollama:11434
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:3b

# --- App ports ---
FASTAPI_PORT=8000
STREAMLIT_PORT=8501
